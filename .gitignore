# 🗄️ GITIGNORE - RH+ SISTEMA DE GESTÃO
# Proteção de dados sensíveis e arquivos de desenvolvimento

# ===========================================
# 🔐 DADOS SENSÍVEIS E CONFIGURAÇÕES
# ===========================================
# Proteger APENAS arquivos com senhas e dados críticos
# Permitir documentação geral e arquivos de configuração (sem senhas)

# Arquivos de ambiente com senhas (proteger apenas os que contêm senhas reais)
.env
.env.local
.env.production

# PERMITIR arquivos de exemplo para análise do Cascade
!.env.example
!.env.test
!.env.development.example

# Backup de bancos de dados (proteger apenas backups reais)
*.sql
*.sql.gz
*.backup
*.dump

# PERMITIR arquivos SQL de migração e estrutura
!migrations/**/*.sql
!dados-config/bancos/**/*.sql
!scripts/*.sql

# Scripts com credenciais (proteger apenas os com senhas reais)
scripts/backup-*.sh
scripts/deploy-*.sh
scripts/migrar-*.sh

# PERMITIR scripts de documentação e exemplo
!dados-config/**/*.sh
!scripts/setup*.js
!scripts/db-*.js
!scripts/check-*.js

# ===========================================
# 📁 DEPENDÊNCIAS E NODE.JS
# ===========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ===========================================
# 📊 LOGS E ARQUIVOS TEMPORÁRIOS
# ===========================================
# Proteger logs reais com dados sensíveis
logs/
*.log
access.log
error.log
pm2-logs/

# PERMITIR estrutura de diretórios para análise
!logs/.gitkeep

# Arquivos temporários
tmp/
temp/

# ===========================================
# 💾 BANCOS DE DADOS LOCAIS
# ===========================================
*.sqlite
*.sqlite3
*.db
*.db-journal

# ===========================================
# 🖥️ ARQUIVOS DE SISTEMA E IDE
# ===========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE e editores
.vscode/
.idea/
*.swp
*.swo
*~

# ===========================================
# 🔧 FERRAMENTAS E BUILD
# ===========================================
build/
dist/
.cache/
.parcel-cache/

# ===========================================
# 📱 ARQUIVOS DE UPLOAD E MÍDIA
# ===========================================
# Proteger uploads reais com dados de usuários
uploads/
public/uploads/
public/assets/temp/
*.tmp

# PERMITIR estrutura de diretórios para análise
!uploads/.gitkeep
!public/uploads/.gitkeep
!public/assets/temp/.gitkeep

# ===========================================
# 🗂️ BACKUPS E COMPACTADOS
# ===========================================
# Proteger backups reais com dados sensíveis
backups/
*.zip
*.tar.gz
*.rar
*.7z

# PERMITIR estrutura de diretórios para análise
!backups/.gitkeep
!dados-config/backup/

# ===========================================
# 📋 DOCUMENTOS E RELATÓRIOS TEMPORÁRIOS
# ===========================================
*.pdf
*.docx
*.xlsx
*.txt
*.md.temp
README.temp

# ===========================================
# 🌐 CERTIFICADOS E CHAVES
# ===========================================
*.pem
*.key
*.crt
*.p12
*.pfx
certificados/
ssl/

# ===========================================
# 📊 ARQUIVOS DE TESTE E COBERTURA
# ===========================================
coverage/
.nyc_output/
junit.xml
test-results/

# ===========================================
# 🔄 SCRIPTS PERSONALIZADOS
# ===========================================
scripts/local/
scripts/temp/
*.local.sh
*.local.bat

# ===========================================
# 📦 PM2 E PROCESS MANAGERS
# ===========================================
ecosystem.config.js.local
pm2-logs/
.pm2/

# ===========================================
# 🔍 ARQUIVOS DE ANÁLISE E DEBUG
# ===========================================
*.prof
*.heap
*.cpuprofile
debug.log

# ===========================================
# 📅 AGENDAMENTO E CRON
# ===========================================
crontab.tmp
cron.*.tmp

# ===========================================
# 🌍 VARIÁVEIS ESPECÍFICAS DE AMBIENTE
# ===========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===========================================
# 🚀 DEPLOY E PRODUÇÃO
# ===========================================
# Arquivos que só devem existir na VPS
/etc/nginx/sites-available/rh.nordesteloc.cloud
/etc/ssl/certs/rh.nordesteloc.cloud*
/usr/local/bin/backup-*

# ===========================================
# 📝 NOTAS FINAIS
# ===========================================
# - Este .gitignore protege dados sensíveis específicos
# - Permite documentação geral em dados-config/
# - Mantém o repositório limpo e seguro
# - Permite apenas código fonte e documentação pública
