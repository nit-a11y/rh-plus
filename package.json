{
  "name": "rh-plus",
  "version": "2.0.0",
  "description": "Sistema Profissional de Gestão de RH - Nordeste Locações",
  "main": "backend/server.js",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node backend/server.js",
    "dev": "cross-env NODE_ENV=development nodemon backend/server.js",
    "test": "cross-env NODE_ENV=test jest",
    "setup": "node scripts/setup.js",
    "db:status": "node scripts/db-manager.js status",
    "db:migrate": "node scripts/db-manager.js migrate",
    "db:seed": "node scripts/db-manager.js seed",
    "seed:users": "node scripts/seed-users.js",
    "db:reset": "node scripts/db-manager.js reset",
    "db:backup": "node scripts/db-manager.js backup",
    "db:help": "node scripts/db-manager.js help",
    "db:sync-sqlite": "node scripts/migrate-sqlite-to-postgres.js",
    "db:inject-f6b42ec3": "node scripts/inject-employee-f6b42ec3.js",
    "deploy:check": "node scripts/deploy-check.js",
    "lint": "eslint backend/",
    "logs": "node -e \"require('child_process').spawn('tail', ['-f', 'logs/app.log'], {stdio: 'inherit'})\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3"
  },
  "keywords": [
    "rh",
    "hr",
    "postgresql",
    "nodejs",
    "gestao"
  ],
  "author": "Nordeste Locações",
  "license": "PRIVATE"
}
